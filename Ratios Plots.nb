           RowBox[{"ratioCleanSeries", "[", "denIn", "]"}], ",", " ", 
           RowBox[{
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{"#", "[", 
               RowBox[{"[", "2", "]"}], "]"}], "]"}], " ", ">", " ", "eps"}], 
            " ", "&"}]}], "]"}]}], ";", "\n", "\n", "  ", 
        RowBox[{"If", "[", 
         RowBox[{
