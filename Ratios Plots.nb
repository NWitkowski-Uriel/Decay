            " ", 
           RowBox[{
            RowBox[{"Length", "[", "den", "]"}], " ", "<", " ", "2"}]}], ",", 
          " ", 
          RowBox[{"Return", "[", 
           RowBox[{"{", "}"}], "]"}]}], "]"}], ";", "\n", "\n", "  ", 
        RowBox[{"xMin", " ", "=", " ", 
         RowBox[{"Min", "[", 
          RowBox[{"den", "[", 
           RowBox[{"[", 
