          RowBox[{"Return", "[", 
           RowBox[{"{", "}"}], "]"}]}], "]"}], ";", "\n", "\n", "  ", 
        RowBox[{"ratio", " ", "=", " ", 
         RowBox[{"Table", "[", "\n", "    ", 
          RowBox[{
