     RowBox[{"Module", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "num", ",", " ", "den", ",", " ", "denInterp", ",", " ", "xMin", ",", 
         " ", "xMax", ",", " ", "ratio", ",", " ", 
         RowBox[{"eps", " ", "=", " ", 
          RowBox[{"10", "^", 
