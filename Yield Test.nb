Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "==="}], " ", 
   "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"COMPACT", " ", "NORMALIZATION", " ", "TESTS"}], 
   "                                  ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "==="}], " ", 
   "*)"}], "\n", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", 
     RowBox[{
     "compactRowsForMode", ",", " ", "CompactYieldChecksVacuum", ",", " ", 
      "CompactYieldChecksFitted", ",", " ", "YieldChecks"}], "]"}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"compactRowsForMode", "[", "mode_String", "]"}], " ", ":=", " ", 
     RowBox[{"Module", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"typeAssoc", " ", "=", " ", 
          RowBox[{"yieldTypesByMode", "[", "mode", "]"}]}], ",", " ", "rowN", 
         ",", " ", "rowPi"}], "}"}], ",", "\n", "  ", 
       RowBox[{
        RowBox[{"rowN", " ", "=", " ", 
         RowBox[{"Prepend", "[", "\n", "    ", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"ytRatio", "[", 
               RowBox[{
                RowBox[{"gN", "*", 
                 RowBox[{"daughterYield", "[", 
                  RowBox[{
                   RowBox[{"typeAssoc", "[", "#", "]"}], ",", 
                   " ", "\"\<Dpp\>\"", ",", " ", "\"\<p\>\""}], "]"}]}], ",", 
                " ", 
                RowBox[{"parentYield", "[", 
                 RowBox[{
