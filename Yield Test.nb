             "    ", "]"}], ",", "\n", "    ", 
            RowBox[{"Missing", "[", "\"\<Failed\>\"", "]"}]}], "\n", "  ", 
           "]"}]}]}], ";", "\n", "  ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"ytFiniteNumberQ", "[", "res", "]"}], ",", " ", 
          RowBox[{"N", "[", "res", "]"}], ",", " ", 
          RowBox[{"Missing", "[", "\"\<NonNumeric\>\"", "]"}]}], "]"}]}]}], 
      "\n", "]"}]}], ";"}], "\n", "\n", 
